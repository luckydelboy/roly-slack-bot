# Slack Bot Tokens (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Anthropic API Key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Bot Configuration
BOT_NAME=Roly
MAX_CONVERSATION_HISTORY=20
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# Creative & Research Models
CREATIVE_MODEL=claude-opus-4-20250514
RESEARCH_MODEL=claude-sonnet-4-20250514
RESEARCH_MAX_TOKENS=16384
ADVERTORIAL_MAX_TOKENS=16384
LISTICLE_MAX_TOKENS=12288

# Vercel (for auto-deploying advertorials/listicles)
VERCEL_API_TOKEN=vcp_your-vercel-api-token

# Reddit (optional — for review scraping)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=RolyBot/1.0
